# Copy this file to .env and fill in your own values. Never commit the real .env file.
PORT=4000
AWS_REGION=us-east-2
S3_BUCKET=cloudlocker-files-yourname
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# Only needed for LOCAL development (your laptop).
# On EC2, leave these two blank/unset entirely - the attached IAM role
# (cloudlocker-ec2-role) provides credentials automatically and
# the AWS SDK picks them up with zero config.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
